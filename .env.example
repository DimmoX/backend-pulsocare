# ==========================================================================
# PulsoCare - plantilla de variables de entorno para docker-compose
# Copia este archivo a .env y completa los valores. .env NO se versiona.
# ==========================================================================

# --- Base de datos Oracle Autonomous --------------------------------------
DB_USER=ADMIN
DB_PASSWORD=cambia-esto
DB_DSN=bdpulsocaretads_low

# --- Frontend (origen permitido para CORS) --------------------------------
FRONTEND_ORIGIN=http://localhost:4200

# --- Azure AD B2C (ms-auth crea usuarios via Microsoft Graph) -------------
# App registration de backend con permiso User.ReadWrite.All (admin consent).
B2C_ENABLED=false
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_ISSUER_DOMAIN=pulsocareduoc.onmicrosoft.com

# --- Solo si levantas ms-notification (perfil "notificaciones") -----------
# Credenciales temporales de AWS Academy (incluyen session token).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
SQS_QUEUE_URL=
SNS_TOPIC_ARN=

# ms-auth suscribe el correo del usuario al topic (SNS_TOPIC_ARN) al crearlo,
# filtrado por su id_usuario. Requiere credenciales AWS (LabRole en la instancia).
SNS_SUBSCRIBE_ENABLED=false

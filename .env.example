# ==========================================================================
# PulsoCare - plantilla de variables de entorno para docker-compose
# Copia este archivo a .env y completa los valores. .env NO se versiona.
# ==========================================================================

# --- Base de datos Oracle Autonomous --------------------------------------
DB_USER=ADMIN
DB_PASSWORD=cambia-esto
DB_DSN=bdpulsocaretads_low

# --- Frontend (origen permitido para CORS) --------------------------------
FRONTEND_ORIGIN=http://localhost:4200

# --- Solo si levantas ms-notification (perfil "notificaciones") -----------
# Credenciales temporales de AWS Academy (incluyen session token).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
SQS_QUEUE_URL=
SNS_TOPIC_ARN=
